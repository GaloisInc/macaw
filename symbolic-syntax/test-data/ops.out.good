(defun @ops ((p Pointer) (q Pointer)) Unit
   (start start:
      (let b (bv-typed-literal SizeT 42))
      (let bp (bits-to-pointer b))
      (let pb (pointer-to-bits bp))
      (let n (pointer-make-null))
      (let g (global-ptr 0 4096))
      (let d (pointer-diff p q))
      (let r (pointer-add p d))
      (let s (pointer-sub r d))
      (let u (pointer-and r s))
      (let v (pointer-xor s u))
      (let e (pointer-eq s p))
      (let l (pointer-leq s p))
      (let L (pointer-lt s p))
      (let t (pointer-read Int le s))
      (pointer-write SizeT le s b)
      (let x (pointer-mux e u v))
      (let bv1 (bv-typed-literal (Bitvector 64) 100))
      (let bv2 (bv-typed-literal (Bitvector 64) 200))
      (let carry #f)
      (let uadc_overflow (overflows uadc 64 bv1 bv2 carry))
      (let sadc_overflow (overflows sadc 64 bv1 bv2 carry))
      (let usbb_overflow (overflows usbb 64 bv1 bv2 carry))
      (let ssbb_overflow (overflows ssbb 64 bv1 bv2 carry))
      (let p32 (pointer-trunc 64 32 p))
      (let p128 (pointer-uext 32 128 p32))
      (let fresh_bool (fresh-symbolic MacawBool))
      (let fresh_bv (fresh-symbolic (MacawBV 64)))
      (let default_val (bv-typed-literal Int 0))
      (let cond_read_result
           (pointer-cond-read Int le e p default_val))
      (let write_val (bv-typed-literal SizeT 42))
      (pointer-cond-write SizeT le e p write_val)
      (return ())))

ops
%0
